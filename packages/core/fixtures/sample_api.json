{
  "openapi": "3.0.0",
  "info": {
    "title": "Sample API",
    "version": "1.0.0"
  },
  "paths": {
    "/hello": {
      "get": {
        "responses": {
          "200": {
            "description": "Hello",
            "content": {
              "application/json": {
                "example": {
                  "message": "Hello World"
                }
              }
            }
          }
        }
      }
    },
    "/echo": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Echo back the request",
            "content": {
              "application/json": {
                "example": {
                  "message": "Received"
                }
              }
            }
          }
        }
      }
    }
  }
}
